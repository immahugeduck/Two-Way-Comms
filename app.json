{
  "expo": {
    "name": "2Way",
    "slug": "2way-secure-walkie",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.twoway.securechat",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "2Way needs microphone access for push-to-talk voice messages.",
        "NSCameraUsageDescription": "2Way needs camera access to set your profile photo.",
        "NSPhotoLibraryUsageDescription": "2Way needs photo library access to set your profile photo."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.twoway.securechat",
      "permissions": [
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/logo.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "Allow 2Way to access the microphone for push-to-talk."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/logo.png",
          "color": "#00D4AA",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "#{unread_notifications} new messages",
          "iosDisplayInForeground": true
        }
      ],
      "expo-font"
    ],
    "scheme": "twoway",
    "experiments": {
      "typedRoutes": true
    }
  }
}
