{
  "expo": {
    "name": "Relay",
    "slug": "relay-secure-walkie",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.relay.securechat",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Relay needs microphone access for push-to-talk voice messages.",
        "NSCameraUsageDescription": "Relay needs camera access to set your profile photo.",
        "NSPhotoLibraryUsageDescription": "Relay needs photo library access to set your profile photo."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.relay.securechat",
      "permissions": [
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "Allow Relay to access the microphone for push-to-talk."
        }
      ]
    ],
    "scheme": "relay",
    "experiments": {
      "typedRoutes": true
    }
  }
}
